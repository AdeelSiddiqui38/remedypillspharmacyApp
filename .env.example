# =============================
# Remedy Pills Pharmacy - ENV
# =============================
# Server
NODE_ENV=production
PORT=5000
APP_BASE_URL=https://your-domain.example  # no trailing slash
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_BOOTSTRAP_PASSWORD=  # required to create the initial 'admin' user on first run

# Database (Postgres)
DATABASE_URL=postgres://user:password@host:5432/dbname

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Contact form webhook from remedypills.ca (Elementor Forms "Webhook" action)
CONTACT_WEBHOOK_SECRET=

# Email (optional - for sending emails)
GMAIL_APP_PASSWORD=

# Twilio (optional - for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_KEY_SECRET=
TWILIO_FROM_NUMBER=

# DigitalOcean Spaces (object storage for admin SMS media uploads)
SPACES_REGION=tor1
SPACES_BUCKET=
SPACES_KEY=
SPACES_SECRET=

# OpenAI (optional - for food analysis)
OPENAI_API_KEY=
# OPENAI_BASE_URL=
